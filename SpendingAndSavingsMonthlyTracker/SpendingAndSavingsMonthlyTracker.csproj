    <PackageReference Include="Dapper" Version="2.1.66" />
    <PackageReference Include="Syncfusion.Blazor.Core" Version="28.2.7" />
    <PackageReference Include="Z.Dapper.Plus" Version="7.5.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommonClasses\CommonClasses.csproj" />
  </ItemGroup>

</Project>
